<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            background-color: #0d1117; /* Темний фон GitHub */
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        img {
            width: 400px;
            height: 400px;
            object-fit: contain;
            /* Якщо твоєї картинки нема, покажеться рамка зі світінням */
            border: 2px dashed #58a6ff; 
            border-radius: 20px;
        }
    </style>
</head>
<body>

    <!-- ВАЖЛИВО: Перевір, щоб файл реально лежав у папці assets під назвою logo.png -->
    <img src="assets/logo.png" onerror="this.src='https://cdn-icons-png.flaticon.com'; this.style.border='none';">

</body>
</html>

